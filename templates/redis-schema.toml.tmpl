# Redis Key Namespace Schema
# Generated by schema-architect skill
# Service: {{SERVICE_NAME}}
# Date: {{DATE}}

[service]
name = "{{SERVICE_NAME}}"
version = "1.0.0"
default_ttl_seconds = 300

{{#NAMESPACES}}
[namespaces.{{NAMESPACE_NAME}}]
pattern = "{{SERVICE_NAME}}:{{PATTERN}}"
ttl_seconds = {{TTL}}
sliding = {{SLIDING}}
description = "{{DESCRIPTION}}"
{{/NAMESPACES}}

